### ===== Gateway üzerinden (port 8090) =====

### 1. Create User (public - no auth needed)
POST http://localhost:8090/users/create
Content-Type: application/json

{
  "username": "testuser",
  "password": "password123",
  "email": "testuser@gmail.com",
  "firstName": "Test",
  "lastName": "User",
  "phoneNumber": "5551234567"
}

> {%
    client.test("Create User - should return 201", function () {
        client.assert(response.status === 201, "Expected 201 Created");
        client.assert(response.body.username === "testuser");
        client.global.set("created_user_id", response.body.id);
    });
%}

###
### 2. Create User - Duplicate (should fail 409)
POST http://localhost:8090/users/create
Content-Type: application/json

{
  "username": "testuser",
  "password": "password123",
  "email": "testuser@gmail.com"
}

> {%
    client.test("Duplicate User - should return 409", function () {
        client.assert(response.status === 409, "Expected 409 Conflict");
        client.assert(response.body.code === "ALREADY_EXISTS");
    });
%}

###
### 3. Login (public - no auth needed)
POST http://localhost:8090/users/login
Content-Type: application/json

{
  "username": "berkay",
  "password": "admin"
}

> {%
    client.test("Login - should return 200 with token", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        client.assert(response.body.token !== null, "Token should not be null");
        client.global.set("auth_token", response.body.token);
        client.global.set("admin_id", response.body.user.id);
    });
%}

###
### 4. Login - Wrong Password (should fail 401)
POST http://localhost:8090/users/login
Content-Type: application/json

{
  "username": "admin",
  "password": "wrongpassword"
}

> {%
    client.test("Bad Login - should return 401", function () {
        client.assert(response.status === 401, "Expected 401 Unauthorized");
        client.assert(response.body.code === "INVALID_CREDENTIALS");
    });
%}

###
### 5. Get User by ID (authenticated)
GET http://localhost:8090/users/id/{{created_user_id}}
Authorization: Bearer {{auth_token}}

> {%
    client.test("Get User by ID - should return 200", function () {
        client.assert(response.status === 200, "Expected 200 OK");
        client.assert(response.body.id !== null);
    });
%}

###
